# Raiz — referência rápida. Copie os exemplos reais em:
#   frontend/.env.local
#   backend/.env

# Supabase (Postgres) — obter no painel do projeto
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@...pooler.../postgres

# NextAuth / Discord (frontend)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# API Nest
# NEXT_PUBLIC_API_URL=http://localhost:3333/api
# BACKEND_INTERNAL_URL=http://localhost:3333/api

# Nest / Prisma (backend)
# JWT_SECRET= (igual ao NEXTAUTH_SECRET recomendado em dev)
# DISCORD_GUILD_ID=
# DISCORD_ADMIN_ROLE_ID=
# DISCORD_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# RESEND_API_KEY=
# EMAIL_FROM=
