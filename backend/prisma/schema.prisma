generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
  INSTRUCTOR
}

model User {
  id            String         @id @default(cuid())
  discordId     String         @unique @map("discord_id")
  username      String
  avatar        String?
  email         String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  adminLogs     Log[]          @relation("AdminLogs")
  notifications Notification[]

  @@map("users")
}

/// Cadastro de quem pede acesso ao painel (instrutor). Liberação manual: `users.role` = INSTRUCTOR no banco.
model InstructorRegistration {
  id          String   @id @default(cuid())
  discordId   String   @unique @map("discord_id")
  fullName    String   @map("full_name")
  rg          String
  phone       String
  graduation  String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("instructor_registrations")
}

model Course {
  id             String        @id @default(cuid())
  name           String        @unique @map("title")
  description    String
  requirements   String        @default("")
  duration       String
  slots          Int           @default(0) @map("vacancies")
  status         String        @default("OPEN")
  createdAt      DateTime      @default(now()) @map("created_at")
  applications   Application[]

  @@map("courses")
}

model Application {
  id                 String            @id @default(cuid())
  fullName           String            @map("full_name")
  age                Int
  cpf                String
  discordTag         String            @map("discord")
  discordUserId      String?           @map("discord_user_id")
  email              String
  phone              String
  city               String
  state              String
  desiredCourse      String            @map("desired_course")
  experience         String?           @map("previous_experience")
  motivation         String
  acceptedTerms      Boolean           @default(false) @map("accepted_terms")
  status             ApplicationStatus @default(PENDING)
  course             Course            @relation(fields: [courseId], references: [id])
  courseId           String            @map("course_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@index([courseId])
  @@map("applications")
}

model Log {
  id        String   @id @default(cuid())
  adminId   String?  @map("admin_id")
  admin     User?    @relation("AdminLogs", fields: [adminId], references: [id], onDelete: SetNull)
  action    String
  targetId  String?  @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  read      Boolean  @default(false) @map("read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}
