NEXT_PUBLIC_API_URL="https://two7bi.onrender.com/api"

# Next.js (route /api/applications) chama o Nest no servidor; use a mesma base em produção
BACKEND_INTERNAL_URL="https://two7bi.onrender.com/api"

# ID do curso único (Paraquedista) — deve ser o mesmo `id` criado no seed do backend.
NEXT_PUBLIC_PARAQUEDISTA_COURSE_ID="clcoursearquiteto001"
